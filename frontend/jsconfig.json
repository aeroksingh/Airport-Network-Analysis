{
	"compilerOptions": {
		"baseUrl": "./src",
		"paths": {
			"@/*": ["*"]
		},
		"target": "ES2020",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"moduleResolution": "node",
		"allowJs": true,
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "build"]
}