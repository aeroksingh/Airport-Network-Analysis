# ─── Frontend .env.example ───────────────────────────────────────────────────
# Copy this to .env (CRA reads .env automatically)

# FIX (PORT): Lock port to 3001 — prevents CRA from auto-incrementing
PORT=3001

# Backend URLs — no trailing slashes
REACT_APP_API_URL=http://localhost:5000
REACT_APP_SOCKET_URL=http://localhost:5000
