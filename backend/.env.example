# ─── Backend .env.example ────────────────────────────────────────────────────
# Copy this to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/airportdb

# JWT — keep this secret, min 32 chars
JWT_SECRET=change_this_to_a_random_32_char_secret
# FIX (MEDIUM): reduced from 7d to 1h. Use refresh tokens for longer sessions.
JWT_EXPIRY=1h

# FIX (MEDIUM): CORS — set to your actual frontend origin (no trailing slash)
FRONTEND_ORIGIN=http://localhost:3001

# FIX (MEDIUM): SSRF — comma-separated list of allowed transfer destinations
# Leave empty to block all outbound file transfers
ALLOWED_TRANSFER_HOSTS=

# Optional: enable UDP heartbeat (set to 'false' to disable)
ENABLE_UDP_HEARTBEAT=true
